# Gaming Behavior ML API - Environment Configuration
# Copy this file to .env and modify as needed

# Server settings
GAMING_ML_HOST=0.0.0.0
GAMING_ML_PORT=8000

# CORS - comma-separated origins
GAMING_ML_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Rate limiting
GAMING_ML_RATE_LIMIT=30/minute

# API keys - comma-separated, leave empty to disable auth
# Generate with: python -c "from src.config import settings; print(settings.generate_api_key())"
GAMING_ML_API_KEYS=

# Logging
GAMING_ML_LOG_LEVEL=INFO
